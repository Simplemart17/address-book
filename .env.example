# App — public base URL, used for absolute Open Graph / social-share image URLs.
# On Vercel this falls back to VERCEL_PROJECT_PRODUCTION_URL automatically; set
# this explicitly for a custom domain (no trailing slash).
NEXT_PUBLIC_APP_URL='https://your-domain.com'

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY='your-clerk-publishable-key'
CLERK_SECRET_KEY='your-clerk-secret-key'
NEXT_PUBLIC_CLERK_SIGN_IN_URL='/sign-in'
NEXT_PUBLIC_CLERK_SIGN_UP_URL='/sign-up'
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL='/contact-lists'
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL='/contact-lists'

# Supabase (shared project; this app lives in the "contacts" schema)
NEXT_PUBLIC_SUPABASE_URL='your-shared-supabase-project-url'
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY='sb_publishable_...'
SUPABASE_SECRET_KEY='sb_secret_...'
